# Database connection. Used by both the Prisma CLI and Next.js.
# The Prisma CLI only reads .env, so keep DATABASE_URL in .env locally.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shardup?schema=public"

# Auth.js
AUTH_URL="http://localhost:3000"
AUTH_SECRET="replace-with-a-random-secret"
AUTH_TRUST_HOST="true"
AUTH_GOOGLE_ID="replace-with-google-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-client-secret"

# Comma-separated emails that should automatically become admins.
# Include admin@shardup.local to make the dev admin sign-in an actual admin.
ADMIN_EMAILS="admin@shardup.local,admin@example.com"

# Development-only sign-in (disabled automatically in production). When "true",
# the /join page offers "Continue as applicant (dev)" and "Continue as admin (dev)"
# so the full flow can be tested without Google credentials.
LOCAL_DEV_AUTH_ENABLED="false"

# Practice problem judge.
# Use JUDGE_PROVIDER="fake" only for local/E2E smoke tests.
# For real submissions, host Piston yourself and point this at its /api/v2 base path.
JUDGE_PROVIDER="piston"
JUDGE_BASE_URL="http://localhost:2000/api/v2"
JUDGE_API_KEY="replace-with-proxy-api-key"
PISTON_PYTHON_VERSION="3.10.0"
PISTON_CPP_VERSION="10.2.0"
